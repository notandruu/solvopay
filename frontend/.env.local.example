# WalletConnect project ID — get one at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=YOUR_WALLETCONNECT_PROJECT_ID

# Deployed SessionFactory address
# Base Sepolia testnet:
NEXT_PUBLIC_FACTORY_ADDRESS=0x5E6bb045A958B7613A79F2E9DC0918519F25290c
# Base mainnet (after deploy):
# NEXT_PUBLIC_FACTORY_ADDRESS=0xYOUR_MAINNET_FACTORY_ADDRESS

# USDC address for the target chain
# Base mainnet: 0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
# Base Sepolia:  0xba50Cd2A20f6DA35D788639E581bca8d0B5d4D5f
NEXT_PUBLIC_USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# Optional: backend API URL for session state persistence
NEXT_PUBLIC_BACKEND_URL=https://your-backend.railway.app
