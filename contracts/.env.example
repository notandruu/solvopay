# Base mainnet (enable "Base Mainnet" in your Alchemy app's Networks tab)
ALCHEMY_BASE_MAINNET_RPC=https://base-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# Base Sepolia testnet
ALCHEMY_BASE_SEPOLIA_RPC=https://base-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# Deployer wallet private key (0x-prefixed)
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY
