# Postgres connection string
# On Railway: injected automatically when you add the Postgres plugin
# Locally: postgresql+asyncpg://user:password@localhost:5432/solvopay
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/solvopay

# Alchemy RPC — must have Base Mainnet enabled in your Alchemy app
ALCHEMY_BASE_MAINNET_RPC=https://base-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# Alchemy webhook signing key — copy from the webhook's detail page after creating it
ALCHEMY_WEBHOOK_SIGNING_KEY=YOUR_WEBHOOK_SIGNING_KEY

# EOA private key used to submit settle() transactions on-chain
BACKEND_EOA_PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# Deployed SessionFactory address (output of hardhat deploy script)
SESSION_FACTORY_ADDRESS=0xYOUR_DEPLOYED_FACTORY_ADDRESS
